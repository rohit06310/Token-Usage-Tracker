# =============================================================================
# Unified AI Usage Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database (Supabase PostgreSQL) ------------------------------------------
# Get this from: Supabase Dashboard → Project → Settings → Database → URI
# Direct connection (port 5432) — recommended for SQLAlchemy + Alembic
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- Encryption ---------------------------------------------------------------
# Fernet symmetric key for encrypting API keys at rest.
# Generate with: python scripts/generate_keys.py
FERNET_KEY=your-base64-fernet-key-here

# --- Dashboard Auth -----------------------------------------------------------
# The API key used to authenticate requests to THIS dashboard's own endpoints.
# Generate with: python scripts/generate_keys.py
# Store the raw value here — it will be hashed on startup for comparison.
DASHBOARD_API_KEY=your-dashboard-api-key-here

# --- JWT Secret Key -----------------------------------------------------------
# REQUIRED in production. Used to sign and verify JWT access tokens.
# ⚠️  MUST be changed from the default — any deployment with the default key
#     is vulnerable to JWT forgery.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-64-char-hex-secret-here

# --- Provider API Keys (Optional) ---------------------------------------------
# You can store keys here for single-tenant use, OR store them securely in the
# database via POST /api/v1/api-keys/ (preferred for multi-tenant setups).
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GROQ_API_KEY=gsk_your_groq_key
GEMINI_API_KEY=AIza_your_gemini_key

# --- Scheduler & Alerts ---------------------------------------------------------
# Fetches provider-reported billing usage for reconciliation
SCHEDULER_ENABLED=true
USAGE_FETCH_INTERVAL_HOURS=6

# Slack Webhook for Alerts
SLACK_WEBHOOK_URL=

# Generic HTTP POST Webhook for Alerts (PagerDuty, Discord, Teams, etc.)
GENERIC_WEBHOOK_URL=

# SMTP Email for Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# Alert Thresholds (comma separated percentages)
ALERT_THRESHOLDS=80,95

# --- App Settings -------------------------------------------------------------
APP_ENV=development
APP_NAME=Unified AI Usage Dashboard
APP_VERSION=0.2.0
DEBUG=true
LOG_LEVEL=INFO

# --- CORS (comma-separated list of allowed origins) --------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
